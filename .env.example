APP_NAME=kanika-demo
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
TRUST_PROXY_HEADERS=false
JWT_SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_NAME=kanika_demo_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_PATH=/
AUTH_COOKIE_DOMAIN=
CSRF_COOKIE_NAME=kanika_demo_csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
AUTH_LOGIN_RATE_LIMIT_REQUESTS=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_SENSITIVE_RATE_LIMIT_REQUESTS=30
AUTH_SENSITIVE_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With,X-CSRF-Token
CORS_EXPOSE_HEADERS=Retry-After,X-Request-ID
CORS_ALLOW_CREDENTIALS=true
MONGO_ROOT_USERNAME=kanika_root
MONGO_ROOT_PASSWORD=replace-with-a-strong-mongo-root-password
MONGO_APP_USERNAME=kanika_app
MONGO_APP_PASSWORD=replace-with-a-strong-mongo-app-password
MONGO_DB_NAME=kanika_demo
MONGO_URI=mongodb://kanika_app:replace-with-a-strong-mongo-app-password@mongo:27017/kanika_demo?authSource=kanika_demo
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_CSRF_COOKIE_NAME=kanika_demo_csrf_token
VITE_CSRF_HEADER_NAME=X-CSRF-Token
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_PRICING_MODEL=gpt-5.2
SEED_PATH_INGESTION_ENABLED=false
SEED_INGESTION_ROOT=/absolute/path/for/seed-ingestion
MASTER_ADMIN_EMAIL=bootstrap-admin@example.com
MASTER_ADMIN_PASSWORD=replace-with-a-strong-bootstrap-password
MASTER_ADMIN_FULL_NAME=System Admin
